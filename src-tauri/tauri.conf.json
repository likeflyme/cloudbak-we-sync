{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "we-sync",
  "version": "1.2.0",
  "identifier": "org.cloudbak.we-sync",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "We Sync",
        "width": 800,
        "height": 600,
        "label": "main"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.we-sync/avatars/**",
          "$APPDATA/.we-sync/avatars/**",
          "$APPLOCALDATA/.we-sync/avatars/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/likeflyme/cloudbak-we-sync/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxQzczQUZDOTgxRUY4MjkKUldRcCtCNlkvRHJIWVFxWmNndGF6S2lkRWZ4S1BlUWQyazc1V3YxNmUxa2I0dStkWlJDVDNDdWYK"
    },
    "store": null
  }
}